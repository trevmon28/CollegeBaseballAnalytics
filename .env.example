# Baseball Analytics — environment variables
# Copy to .env and fill in real values. Never commit .env to git.

# The Odds API key (https://the-odds-api.com) — required for daily bet picks
ODDS_API_KEY=

# Public URL of the deployed REST API (used by mcp_server.py)
# Local development: http://localhost:8000
# VPS production:    https://api.trevormonroe.com
BASEBALL_API_URL=http://localhost:8000

# MCP server transport mode
# stdio  = local Claude Desktop (default, leave unset locally)
# http   = remote Claude.ai / mobile (set this on the VPS)
MCP_TRANSPORT=stdio

# Port for HTTP MCP transport (only used when MCP_TRANSPORT=http)
MCP_PORT=9000
